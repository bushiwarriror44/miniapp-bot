NODE_ENV=development
PORT=3001

# Секретный ключ для доступа к админским и модераторским эндпоинтам (обязательно в продакшене).
# Передаётся в заголовке X-Admin-Key или Authorization: Bearer <key>.
ADMIN_API_KEY=

# Секретный ключ для внутренних запросов от Telegram-бота.
# Передаётся в заголовке X-Bot-Key.
BOT_API_KEY=

# URL контент-API (откуда фронт берёт биржу и горячие предложения).
# При завершении объявления бэкенд вызывает POST {CONTENT_API_URL}/exchange/hide-item.
# Пример: https://admin.teledoska.com/api (без слэша в конце)
CONTENT_API_URL=
CONTENT_API_ADMIN_TOKEN=

# Токен для вызова hide-item (заголовок X-Admin-Token).
# Должен совпадать с ADMIN_API_TOKEN или BACKEND_ADMIN_API_KEY в админке.

# Запускать миграции при старте приложения (1 = да). Иначе выполни вручную: npm run migration:run
# RUN_MIGRATIONS=1

# База miniapp_bot создаётся автоматически при первом запуске бэкенда.
# Пользователь DB_USER должен иметь право CREATEDB (или используй postgres).
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=miniapp_bot

